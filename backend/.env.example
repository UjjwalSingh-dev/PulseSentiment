APP_NAME=PulseSentiment API
APP_ENV=development
DATABASE_URL=sqlite:///./pulse_sentiment.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Set true when you want local demo posts instead of Reddit API calls.
FORCE_DEMO_SOURCE=false

# Optional Reddit API credentials for real Reddit ingestion.
# Create an app at https://www.reddit.com/prefs/apps and choose script type.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PulseSentimentMiniProject/1.0 by your_reddit_username
